[Unit]
Description=EpicBook Node.js Application
Documentation=https://github.com/pravinmishraaws/theepicbook
After=network.target

[Service]
Type=simple
User={{ ansible_user }}
WorkingDirectory={{ epicbook_app_dir }}
Environment="NODE_ENV=production"
EnvironmentFile={{ epicbook_app_dir }}/.env
ExecStart=/usr/bin/node {{ epicbook_app_dir }}/server.js
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=epicbook

[Install]
WantedBy=multi-user.target

